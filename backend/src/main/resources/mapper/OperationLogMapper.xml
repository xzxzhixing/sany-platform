<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sany.platform.mapper.OperationLogMapper">

    <resultMap id="BaseResultMap" type="com.sany.platform.model.entity.OperationLog">
        <id column="id" property="id" />
        <result column="operator" property="operator" />
        <result column="action" property="action" />
        <result column="target" property="target" />
        <result column="detail" property="detail" />
        <result column="ip" property="ip" />
        <result column="create_time" property="createTime" />
    </resultMap>

    <sql id="BaseColumns">
        id, operator, action, target, detail, ip, create_time
    </sql>

    <select id="selectList" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns" /> FROM tbl_operation_log
        <where>
            <if test="action != null and action != ''">
                AND action LIKE CONCAT('%', #{action}, '%')
            </if>
            <if test="operator != null and operator != ''">
                AND operator LIKE CONCAT('%', #{operator}, '%')
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <select id="countList" resultType="long">
        SELECT COUNT(1) FROM tbl_operation_log
        <where>
            <if test="action != null and action != ''">
                AND action LIKE CONCAT('%', #{action}, '%')
            </if>
            <if test="operator != null and operator != ''">
                AND operator LIKE CONCAT('%', #{operator}, '%')
            </if>
        </where>
    </select>
</mapper>
