<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sany.platform.mapper.SparePartMapper">

    <resultMap id="BaseResultMap" type="com.sany.platform.model.entity.SparePart">
        <id column="id" property="id" />
        <result column="part_code" property="partCode" />
        <result column="part_name" property="partName" />
        <result column="specification" property="specification" />
        <result column="unit" property="unit" />
        <result column="stock_quantity" property="stockQuantity" />
        <result column="min_stock" property="minStock" />
        <result column="price" property="price" />
        <result column="remark" property="remark" />
        <result column="deleted" property="deleted" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
    </resultMap>

    <sql id="BaseColumns">
        id, part_code, part_name, specification, unit, stock_quantity, min_stock,
        price, remark, deleted, create_time, update_time
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns" /> FROM tbl_spare_part
        WHERE id = #{id} AND deleted = 0
    </select>

    <select id="selectList" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns" /> FROM tbl_spare_part
        <where>
            deleted = 0
            <if test="partName != null and partName != ''">
                AND part_name LIKE CONCAT('%', #{partName}, '%')
            </if>
            <if test="partCode != null and partCode != ''">
                AND part_code LIKE CONCAT('%', #{partCode}, '%')
            </if>
            <if test="stockStatus != null">
                <choose>
                    <when test="stockStatus == 1">
                        AND stock_quantity &gt; min_stock
                    </when>
                    <when test="stockStatus == 2">
                        AND stock_quantity &gt; 0 AND stock_quantity &lt;= min_stock
                    </when>
                    <when test="stockStatus == 3">
                        AND stock_quantity &lt;= 0
                    </when>
                </choose>
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <select id="countList" resultType="long">
        SELECT COUNT(1) FROM tbl_spare_part
        <where>
            deleted = 0
            <if test="partName != null and partName != ''">
                AND part_name LIKE CONCAT('%', #{partName}, '%')
            </if>
            <if test="partCode != null and partCode != ''">
                AND part_code LIKE CONCAT('%', #{partCode}, '%')
            </if>
            <if test="stockStatus != null">
                <choose>
                    <when test="stockStatus == 1">
                        AND stock_quantity &gt; min_stock
                    </when>
                    <when test="stockStatus == 2">
                        AND stock_quantity &gt; 0 AND stock_quantity &lt;= min_stock
                    </when>
                    <when test="stockStatus == 3">
                        AND stock_quantity &lt;= 0
                    </when>
                </choose>
            </if>
        </where>
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tbl_spare_part (
            part_code, part_name, specification, unit, stock_quantity, min_stock,
            price, remark, deleted, create_time, update_time
        ) VALUES (
            #{partCode}, #{partName}, #{specification}, #{unit}, #{stockQuantity}, #{minStock},
            #{price}, #{remark}, 0, NOW(), NOW()
        )
    </insert>

    <update id="updateById">
        UPDATE tbl_spare_part
        <set>
            update_time = NOW(),
            <if test="partCode != null">part_code = #{partCode},</if>
            <if test="partName != null">part_name = #{partName},</if>
            <if test="specification != null">specification = #{specification},</if>
            <if test="unit != null">unit = #{unit},</if>
            <if test="stockQuantity != null">stock_quantity = #{stockQuantity},</if>
            <if test="minStock != null">min_stock = #{minStock},</if>
            <if test="price != null">price = #{price},</if>
            <if test="remark != null">remark = #{remark},</if>
        </set>
        WHERE id = #{id} AND deleted = 0
    </update>

    <update id="deleteById">
        UPDATE tbl_spare_part SET deleted = 1, update_time = NOW()
        WHERE id = #{id} AND deleted = 0
    </update>
</mapper>
